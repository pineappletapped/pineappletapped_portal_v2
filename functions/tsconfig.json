{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "rootDirs": ["./src", ".."],
    "paths": {
      "../../shared/config/hosting.js": ["../shared/config/hosting.d.ts"],
      "../../shared/config/hosting": ["../shared/config/hosting.d.ts"]
    },
    "outDir": "lib",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": false,
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": [
    "src"
  ]
}