
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() { return request.auth != null; }
    match /orgs/{orgId}/projects/{projectId}/assets/{assetId}/{file=**} {
      allow read, write: if signedIn(); // tighten with Firestore lookups if needed
    }
      // License uploads
      match /orgs/{orgId}/projects/{projectId}/licenses/{file=**} {
        allow read, write: if signedIn();
      }
    match /orgs/{orgId}/brand/logo-prep/{file=**} {
      allow read, write: if signedIn();
    }

    // Brand pack uploads (logos) stored under orgs/{orgId}/brand-packs/{packId}/...
    match /orgs/{orgId}/brand-packs/{packId}/{file=**} {
      allow read, write: if signedIn();
    }

    // Public client logos for homepage
    match /clientLogos/{file=**} {
      allow read: if true;
      allow write: if request.auth != null &&
        get(/databases/(default)/documents/users/$(request.auth.uid)).data.isStaff == true;
    }
  }
}
